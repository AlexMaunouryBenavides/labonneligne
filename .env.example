# Variables d'environnement — La Bonne Ligne (configuration.r4)
# Copier en `.env` ( git-ignoré) et renseigner. Aucune valeur sensible ici.
# Les secrets réels sont injectés via l'environnement Cloudflare Pages, jamais commités.

# — Formulaire de contact (palier 4 : Cloudflare Pages Function + Resend) —
# Clé d'API Resend (secret serveur, jamais exposée au client).
RESEND_API_KEY=
# Adresse de réception des messages du formulaire.
CONTACT_INBOX=
