---
import { plans } from '../data/plans';
import OfferCard from './OfferCard.astro';

interface Props {
  showToggle?: boolean;
}
const { showToggle = true } = Astro.props;
---

<div class="plans">
  {
    showToggle && (
      <div class="plans__toggle" role="group" aria-label="Modo de pago">
        <button type="button" class="plans__opt is-active" data-mode-btn="once" aria-pressed="true">
          Compra única
        </button>
        <button type="button" class="plans__opt" data-mode-btn="month" aria-pressed="false">
          Arriendo / mes
        </button>
      </div>
    )
  }

  <div class="plans__grid" data-mode="once">
    {plans.map((plan) => <OfferCard plan={plan} />)}
  </div>
</div>

<script>
  // astro:page-load : ce composant réapparaît sur plusieurs pages, chacune
  // remplaçant <main> à la navigation — ré-attacher à chaque fois.
  function initPlansToggle() {
    document.querySelectorAll<HTMLElement>('.plans').forEach((root) => {
      const grid = root.querySelector<HTMLElement>('.plans__grid');
      const buttons = root.querySelectorAll<HTMLButtonElement>('[data-mode-btn]');
      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          const mode = button.dataset.modeBtn ?? 'once';
          grid?.setAttribute('data-mode', mode);
          buttons.forEach((other) => {
            const active = other === button;
            other.classList.toggle('is-active', active);
            other.setAttribute('aria-pressed', String(active));
          });
        });
      });
    });
  }

  document.addEventListener('astro:page-load', initPlansToggle);
</script>

<!-- Bascule des prix selon le mode : règle globale (franchit le scoping). -->
<style is:global>
  .plans__grid[data-mode='once'] [data-price='month'],
  .plans__grid[data-mode='month'] [data-price='once'] {
    display: none;
  }
</style>

<style>
  .plans__toggle {
    display: inline-flex;
    border: var(--border-hard);
    margin-bottom: var(--space-lg);
  }
  .plans__opt {
    border: 0;
    background: var(--c-paper);
    cursor: pointer;
    padding: 0.7rem 1.2rem;
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    font-weight: var(--fw-medium);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--c-muted);
    transition:
      background 0.15s var(--ease-out),
      color 0.15s var(--ease-out);
  }
  .plans__opt + .plans__opt {
    border-left: var(--border-hard);
  }
  .plans__opt.is-active {
    background: var(--c-ink);
    color: var(--c-paper);
  }
  .plans__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
    align-items: start;
  }
  @media (max-width: 60rem) {
    .plans__grid {
      grid-template-columns: 1fr;
      max-width: 28rem;
    }
  }
</style>
