---
/**
 * Rangée projet façon éditorial (inspiration bykins.com) : méta à gauche,
 * visuel large à droite. Visuel placeholder tant qu'il n'y a pas de vraies
 * images (dégradé + monogramme + « la ligne »).
 */
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}
const { project } = Astro.props;
const initial = project.name.charAt(0);
---

<article class="prow">
  <div class="prow__meta">
    <p class="prow__sector">{project.sector}</p>
    <h3 class="prow__name">{project.name}</h3>
    <p class="prow__desc">{project.description}</p>
    {
      project.url && (
        <a class="prow__link" href={project.url} target="_blank" rel="noopener">
          Ver sitio <span aria-hidden="true">→</span>
        </a>
      )
    }
  </div>

  <div class="prow__media" aria-hidden="true">
    <span class="prow__initial">{initial}</span>
    <svg class="prow__line" viewBox="0 0 160 90" fill="none" stroke-width="4" stroke-linecap="round">
      <path d="M20 74 L20 30 L88 30" stroke="var(--c-ink)" opacity="0.22"></path>
      <path d="M140 16 L140 60 L88 60" stroke="var(--c-line)"></path>
    </svg>
  </div>
</article>

<style>
  .prow {
    display: grid;
    grid-template-columns: 0.72fr 1.28fr;
    gap: var(--space-xl);
    align-items: center;
    padding-block: var(--space-xl);
    border-top: var(--border-thin);
  }
  .prow:last-child {
    border-bottom: var(--border-thin);
  }

  .prow__sector {
    font-family: var(--font-mono);
    font-size: var(--fs-label);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--c-orange-ink);
  }
  .prow__name {
    font-size: var(--fs-2xl);
    margin-top: var(--space-2xs);
  }
  .prow__desc {
    margin-top: var(--space-xs);
    color: var(--c-muted);
    max-width: 34ch;
  }
  .prow__link {
    display: inline-block;
    margin-top: var(--space-md);
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    color: var(--c-orange-ink);
    text-decoration: none;
  }
  .prow__link:hover {
    text-decoration: underline;
  }

  .prow__media {
    position: relative;
    aspect-ratio: 16 / 10;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: var(--border-thin);
    background:
      radial-gradient(130% 140% at 85% 0%, color-mix(in srgb, var(--c-accent) 14%, transparent), transparent),
      var(--c-paper);
    display: grid;
    place-items: center;
    transition: box-shadow 0.25s var(--ease-out);
  }
  .prow:hover .prow__media {
    box-shadow: var(--shadow-soft);
  }
  .prow__initial {
    font-family: var(--font-display);
    font-size: clamp(4rem, 12vw, 8rem);
    color: var(--c-ink);
    opacity: 0.1;
    line-height: 1;
  }
  .prow__line {
    position: absolute;
    width: 34%;
    height: auto;
    overflow: visible;
  }

  /* Mobile : méta au-dessus, visuel dessous, pleine largeur */
  @media (max-width: 48rem) {
    .prow {
      grid-template-columns: 1fr;
      gap: var(--space-md);
      padding-block: var(--space-lg);
    }
    .prow__desc {
      max-width: none;
    }
  }
</style>
