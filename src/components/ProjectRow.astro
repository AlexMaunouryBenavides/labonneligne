---
/**
 * Rangée projet : méta à gauche, visuel placeholder à droite (bordure/ombre
 * dures, tag numéroté + initiale géante) tant qu'il n'y a pas de vraies
 * captures. Zéro image — cohérent avec le système « sans photo ».
 */
import type { Project } from '../data/projects';

interface Props {
  project: Project;
  index?: number;
}
const { project, index = 0 } = Astro.props;
const initial = project.name.charAt(0);
---

<article class="prow reveal">
  <div class="prow__meta">
    <p class="prow__sector">{project.sector}</p>
    <h3 class="prow__name">{project.name}</h3>
    <p class="prow__desc">{project.description}</p>
    {
      project.url && (
        <a class="prow__link" href={project.url} target="_blank" rel="noopener">
          Ver sitio <span aria-hidden="true">→</span>
        </a>
      )
    }
  </div>

  <div class="prow__media" aria-hidden="true">
    <span class="prow__tag">P—{String(index + 1).padStart(2, '0')}</span>
    <span class="prow__initial">{initial}</span>
  </div>
</article>

<style>
  .prow {
    display: grid;
    grid-template-columns: 0.72fr 1.28fr;
    gap: var(--space-xl);
    align-items: stretch;
    padding-block: var(--space-xl);
    border-top: var(--border-hard);
  }
  .prow:last-child {
    border-bottom: var(--border-hard);
  }

  .prow__meta {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .prow__sector {
    font-family: var(--font-mono);
    font-size: var(--fs-label);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--c-orange-ink);
  }
  .prow__name {
    font-size: var(--fs-2xl);
    margin-top: var(--space-2xs);
  }
  .prow__desc {
    margin-top: var(--space-xs);
    color: var(--c-muted);
    max-width: 34ch;
  }
  .prow__link {
    display: inline-block;
    margin-top: var(--space-md);
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    color: var(--c-orange-ink);
    text-decoration: none;
  }
  .prow__link:hover {
    text-decoration: underline;
  }

  .prow__media {
    position: relative;
    aspect-ratio: 16 / 10;
    border: var(--border-hard);
    background: var(--c-paper-2);
    display: grid;
    place-items: center;
    transition: var(--transition-snap);
  }
  .prow:hover .prow__media {
    box-shadow: var(--shadow-hard);
    transform: translate(-4px, -4px);
  }
  .prow__tag {
    position: absolute;
    top: var(--space-sm);
    left: var(--space-sm);
    font-family: var(--font-mono);
    font-size: var(--fs-label);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-label);
    color: var(--c-orange-ink);
  }
  .prow__initial {
    font-family: var(--font-display);
    font-size: clamp(4rem, 12vw, 8rem);
    color: var(--c-ink);
    opacity: 0.12;
    line-height: 1;
  }

  /* Mobile : méta au-dessus, visuel dessous, pleine largeur */
  @media (max-width: 48rem) {
    .prow {
      grid-template-columns: 1fr;
      gap: var(--space-md);
      padding-block: var(--space-lg);
    }
    .prow__desc {
      max-width: none;
    }
  }
</style>
