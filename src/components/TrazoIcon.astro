---
/**
 * Pictogrammes « tracés » — dessinés à la « ligne » (stroke orange, class
 * .js-draw → se tracent au chargement, motif de marque). Fill none, un trait.
 */
import type { BenefitIcon } from '../data/benefits';
interface Props {
  name: BenefitIcon;
}
const { name } = Astro.props;
---

<svg
  class="trazo-icon"
  viewBox="0 0 48 48"
  fill="none"
  stroke="currentColor"
  stroke-width="2.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  {
    name === 'design' && (
      <>
        <rect class="js-draw" x="6" y="9" width="36" height="30" rx="3" />
        <path class="js-draw" d="M6 18 H42" />
        <path class="js-draw" d="M15 29 l5 5 l11 -12" />
      </>
    )
  }
  {
    name === 'search' && (
      <>
        <circle class="js-draw" cx="21" cy="21" r="13" />
        <path class="js-draw" d="M31 31 L42 42" />
      </>
    )
  }
  {
    name === 'shield' && (
      <>
        <path
          class="js-draw"
          d="M24 5 L41 11 V24 C41 34 33.5 40.5 24 44 C14.5 40.5 7 34 7 24 V11 Z"
        />
        <path class="js-draw" d="M16 24 l5 5 l11 -12" />
      </>
    )
  }
</svg>

<style>
  .trazo-icon {
    display: block;
    width: 3.25rem;
    height: 3.25rem;
    color: var(--c-line);
  }
</style>
