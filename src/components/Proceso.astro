---
/**
 * Section « Proceso » — cartes numérotées empilées (stack), façon spec de
 * processus technique : grand numéro à gauche, contenu + tags à droite,
 * séparées par des filets. Réutilisé sur l'accueil et /nosotros.
 */
import { processSteps } from '../data/process';

const tagsByStep: string[][] = [
  ['WhatsApp', 'Sin compromiso'],
  ['Plazo', 'Precio en CLP'],
  ['Ajustes', 'A tu medida'],
  ['Hosting', 'Mantención'],
];
const steps = processSteps.map((step, i) => ({ ...step, tags: tagsByStep[i] ?? [] }));
---

<ol role="list" class="stack">
  {
    steps.map((step, i) => (
      <li class="stack__card reveal">
        <span class="stack__fill" aria-hidden="true" />
        <div class="stack__step">{String(i + 1).padStart(2, '0')}</div>
        <div class="stack__body">
          <h3 class="stack__title">{step.title}</h3>
          <p class="stack__text">{step.text}</p>
          {step.tags.length > 0 && (
            <div class="stack__tags">
              {step.tags.map((tag, k) => (
                <span class:list={['tag', k === 1 && 'tag--filled']}>{tag}</span>
              ))}
            </div>
          )}
        </div>
      </li>
    ))
  }
</ol>

<script>
  import { gsap } from 'gsap';

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // astro:page-load : <main> est remplacé à chaque navigation (transitions
  // client-side) — ré-attacher les écouteurs sur le DOM frais à chaque fois.
  function initStackHover() {
    document.querySelectorAll<HTMLElement>('.stack__card').forEach((card) => {
      const fill = card.querySelector<HTMLElement>('.stack__fill');
      if (!fill) return;

      const baseRadius = (fill.offsetWidth || 40) / 2;
      gsap.set(fill, { xPercent: -50, yPercent: -50, scale: 0 });

      let originX = 0;
      let originY = 0;

      const place = (e: MouseEvent) => {
        const rect = card.getBoundingClientRect();
        originX = e.clientX - rect.left;
        originY = e.clientY - rect.top;
        gsap.set(fill, { x: originX, y: originY });
      };

      /** Rayon nécessaire pour couvrir tout le rectangle depuis un point d'origine hors-centre. */
      const scaleToCover = () => {
        const rect = card.getBoundingClientRect();
        const corners: Array<[number, number]> = [
          [0, 0],
          [rect.width, 0],
          [0, rect.height],
          [rect.width, rect.height],
        ];
        const maxDist = Math.max(
          ...corners.map((corner) => Math.hypot(corner[0] - originX, corner[1] - originY)),
        );
        return (maxDist / baseRadius) * 1.08;
      };

      card.addEventListener('mouseenter', (e) => {
        place(e);
        card.classList.add('is-active');
        if (prefersReduced) {
          gsap.set(fill, { scale: scaleToCover() });
        } else {
          gsap.to(fill, {
            scale: scaleToCover(),
            duration: 0.55,
            ease: 'power3.out',
            overwrite: true,
          });
        }
      });

      card.addEventListener('mouseleave', (e) => {
        place(e);
        card.classList.remove('is-active');
        if (prefersReduced) {
          gsap.set(fill, { scale: 0 });
        } else {
          gsap.to(fill, { scale: 0, duration: 0.45, ease: 'power2.inOut', overwrite: true });
        }
      });
    });
  }

  document.addEventListener('astro:page-load', initStackHover);
</script>

<style>
  .stack {
    margin: 0;
    display: flex;
    flex-direction: column;
    border: var(--border-hard);
  }
  .stack__card {
    position: relative;
    overflow: hidden;
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: var(--space-lg);
    padding: var(--space-lg);
    align-items: center;
    color: var(--c-ink);
    transition: color 0.35s ease;
  }
  .stack__card.is-active {
    color: var(--c-paper);
  }
  .stack__card + .stack__card {
    border-top: var(--border-hard);
  }
  /* Disque de remplissage — grossit depuis le point d'entrée du curseur (GSAP) */
  .stack__fill {
    position: absolute;
    top: 0;
    left: 0;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: var(--c-ink);
    z-index: 0;
    pointer-events: none;
    will-change: transform;
  }
  .stack__step,
  .stack__body {
    position: relative;
    z-index: 1;
  }
  .stack__step {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1;
    letter-spacing: var(--tracking-tight);
    color: var(--c-line);
  }
  .stack__title {
    font-size: var(--fs-xl);
    line-height: 0.95;
    margin-bottom: var(--space-2xs);
  }
  .stack__text {
    color: var(--c-muted);
    max-width: 46ch;
    transition: color 0.35s ease;
  }
  .stack__card.is-active .stack__text {
    color: rgba(255, 255, 255, 0.72);
  }
  .stack__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xs);
    margin-top: var(--space-sm);
  }

  .tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--fs-label);
    font-weight: var(--fw-medium);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    padding: 0.3em 0.7em;
    border: 2px solid var(--c-ink);
    background: var(--c-paper);
    color: var(--c-ink);
  }
  .tag--filled {
    background: var(--c-ink);
    color: var(--c-paper);
  }

  @media (max-width: 40rem) {
    .stack__card {
      grid-template-columns: 1fr;
      gap: var(--space-sm);
    }
    .stack__step {
      font-size: var(--fs-2xl);
    }
  }
</style>
