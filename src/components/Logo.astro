---
/**
 * Logo « La Bonne Ligne » — mark géométrique statique dans un cadre bordé
 * (esprit Axis Industrial). Coche stylisée en orange sécurité, sans animation :
 * le système « dur » ne fait pas de traits dessinés à la main.
 */
interface Props {
  /** Affiche le mot-symbole « La Bonne Ligne » à côté du monogramme. */
  withWordmark?: boolean;
  /** Taille du cadre (CSS). */
  size?: string;
  class?: string;
}
const { withWordmark = true, size = '1.9rem', class: className = '' } = Astro.props;
---

<span class={`logo ${className}`} style={`--mark-size:${size}`}>
  <span class="logo__mark" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none" stroke="var(--c-line)" stroke-width="2.5">
      <path d="M5 12.5L9.5 17L19 6" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
  </span>

  {
    withWordmark && (
      <span class="logo__wordmark">
        La <span class="logo__accent">Bonne</span> Ligne
      </span>
    )
  }
</span>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    line-height: 1;
  }
  .logo__mark {
    width: var(--mark-size);
    height: var(--mark-size);
    flex: none;
    display: grid;
    place-items: center;
    border: 2px solid var(--c-line);
    background: var(--c-ink);
  }
  .logo__mark svg {
    width: 55%;
    height: 55%;
  }
  .logo__wordmark {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: var(--c-ink);
    white-space: nowrap;
  }
  .logo__accent {
    color: var(--c-orange-ink);
  }
</style>
