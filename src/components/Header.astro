---
import { site } from '../config/site';
import Logo from './Logo.astro';

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname === href || pathname.startsWith(`${href}/`);
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="site-header__brand" href="/" aria-label={`${site.name} — inicio`}>
      <Logo />
    </a>

    <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="primary-nav">
      <span class="nav-toggle__bars" aria-hidden="true"></span>
      <span class="visually-hidden">Abrir menú</span>
    </button>

    <nav id="primary-nav" class="primary-nav" aria-label="Navegación principal">
      <ul role="list" class="primary-nav__list">
        {
          site.nav.map((item) => (
            <li>
              <a
                href={item.href}
                class="primary-nav__link"
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const header = document.querySelector<HTMLElement>('.site-header');
  toggle?.addEventListener('click', () => {
    const open = header?.classList.toggle('site-header--open') ?? false;
    toggle.setAttribute('aria-expanded', String(open));
    toggle.querySelector('.visually-hidden')!.textContent = open ? 'Cerrar menú' : 'Abrir menú';
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--c-paper) 88%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: var(--border-thin);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: var(--header-h);
    gap: var(--space-md);
  }
  .site-header__brand {
    text-decoration: none;
    display: inline-flex;
  }

  .primary-nav__list {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 2.5vw, 2rem);
    margin: 0;
  }
  .primary-nav__link {
    font-size: var(--fs-sm);
    font-weight: var(--fw-medium);
    text-decoration: none;
    color: var(--c-ink);
    padding: 0.4rem 0;
    position: relative;
    transition: color 0.18s var(--ease-out);
  }
  /* La "ligne" sous le lien : se déploie au survol / page active */
  .primary-nav__link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -0.1rem;
    height: 2px;
    width: 100%;
    background: var(--c-line);
    border-radius: var(--radius-pill);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s var(--ease-out);
  }
  .primary-nav__link:hover,
  .primary-nav__link[aria-current='page'] {
    color: var(--c-orange-ink);
  }
  .primary-nav__link:hover::after,
  .primary-nav__link[aria-current='page']::after {
    transform: scaleX(1);
  }

  .nav-toggle {
    display: none;
    width: 2.75rem;
    height: 2.75rem;
    border: var(--border-thin);
    border-radius: var(--radius-sm);
    background: var(--c-paper);
    cursor: pointer;
    place-items: center;
  }
  .nav-toggle__bars,
  .nav-toggle__bars::before,
  .nav-toggle__bars::after {
    content: '';
    display: block;
    width: 1.25rem;
    height: 2px;
    background: var(--c-ink);
    border-radius: 2px;
    transition:
      transform 0.2s var(--ease-out),
      opacity 0.2s var(--ease-out);
  }
  .nav-toggle__bars::before {
    transform: translateY(-6px);
  }
  .nav-toggle__bars::after {
    transform: translateY(4px);
  }

  /* — Mobile — */
  @media (max-width: 48rem) {
    .nav-toggle {
      display: grid;
    }
    .primary-nav {
      position: absolute;
      inset: var(--header-h) 0 auto 0;
      background: var(--c-paper);
      border-bottom: var(--border-thin);
      max-height: 0;
      overflow: hidden;
      /* visibility:hidden retire les liens repliés de l'ordre de tabulation
         (sinon focusables « à l'aveugle » au clavier — ux.r11). */
      visibility: hidden;
      transition:
        max-height 0.3s var(--ease-out),
        visibility 0.3s var(--ease-out);
    }
    .primary-nav__list {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: var(--space-2xs) var(--container-pad) var(--space-md);
    }
    .primary-nav__link {
      display: block;
      padding: var(--space-sm) 0;
      border-bottom: var(--border-thin);
      font-size: var(--fs-lg);
    }
    .primary-nav__link::after {
      display: none;
    }

    .site-header--open .primary-nav {
      max-height: 80svh;
      visibility: visible;
    }
    .site-header--open .nav-toggle__bars {
      background: transparent;
    }
    .site-header--open .nav-toggle__bars::before {
      transform: rotate(45deg);
    }
    .site-header--open .nav-toggle__bars::after {
      transform: rotate(-45deg);
    }
  }
</style>
