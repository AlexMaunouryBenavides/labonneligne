---
import { site } from '../config/site';
import Logo from './Logo.astro';

const year = new Date().getFullYear();
const waHref = `https://wa.me/${site.contact.whatsapp}`;
const social = [
  { label: 'Instagram', href: site.social.instagram },
  { label: 'Facebook', href: site.social.facebook },
  { label: 'TikTok', href: site.social.tiktok },
];
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      <Logo size="2rem" />
      <p class="site-footer__tagline">{site.brandTagline}</p>
    </div>

    <nav class="site-footer__nav" aria-label="Navegación del pie">
      <ul role="list">
        {site.nav.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
      </ul>
    </nav>

    <!-- NAP — ancrage SEO local, présenté en mono (identité "technique") -->
    <address class="site-footer__nap">
      <span class="eyebrow">Contacto</span>
      <a href={`tel:${site.contact.phone.replace(/\s/g, '')}`}>{site.contact.phone}</a>
      <a href={waHref} rel="noopener">WhatsApp</a>
      <a href={`mailto:${site.contact.email}`}>{site.contact.email}</a>
      <span>{site.contact.city}</span>
    </address>
  </div>

  <div class="container site-footer__bar">
    <p>© {year} {site.name}</p>
    <ul role="list" class="site-footer__social">
      {social.map((s) => <li><a href={s.href} rel="noopener">{s.label}</a></li>)}
    </ul>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 3px solid var(--c-line); /* la "ligne" en bord supérieur */
    background: var(--c-paper-2);
    margin-top: var(--space-2xl);
  }
  .site-footer__inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: var(--space-xl);
    padding-block: var(--space-xl) var(--space-lg);
  }
  .site-footer__tagline {
    margin-top: var(--space-sm);
    max-width: 24ch;
    color: var(--c-muted);
    font-size: var(--fs-sm);
  }
  .site-footer__nav ul,
  .site-footer__nap {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    font-style: normal;
  }
  .site-footer__nav a,
  .site-footer__nap a {
    color: var(--c-ink);
    text-decoration: none;
    font-size: var(--fs-sm);
  }
  .site-footer__nav a:hover,
  .site-footer__nap a:hover {
    color: var(--c-orange-ink);
  }
  .site-footer__nap {
    font-family: var(--font-mono);
    gap: var(--space-3xs);
  }
  .site-footer__nap .eyebrow {
    margin-bottom: var(--space-2xs);
  }

  .site-footer__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding-block: var(--space-md);
    border-top: var(--border-thin);
    font-size: var(--fs-label);
    color: var(--c-muted);
  }
  .site-footer__social {
    display: flex;
    gap: var(--space-md);
  }
  .site-footer__social a {
    color: var(--c-muted);
    text-decoration: none;
  }
  .site-footer__social a:hover {
    color: var(--c-orange-ink);
  }

  @media (max-width: 48rem) {
    .site-footer__inner {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }
    .site-footer__bar {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-2xs);
    }
  }
</style>
