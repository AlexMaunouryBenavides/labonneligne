---
/**
 * Placeholder « Próximamente » partagé par les pages encore vides
 * (évite la duplication de structure/style — clean-code.r13).
 * Remplacé par le vrai contenu aux paliers 3-5.
 */
interface Props {
  eyebrow: string;
  title: string;
  note: string;
}
const { eyebrow, title, note } = Astro.props;
---

<section class="section container stub">
  <p class="eyebrow">{eyebrow}</p>
  <h1>{title}</h1>
  <hr class="rule-line" />
  <p class="stub__note">{note}</p>
</section>

<style>
  .stub {
    min-height: 50svh;
  }
  .stub h1 {
    margin-top: var(--space-sm);
  }
  .rule-line {
    margin-block: var(--space-md);
  }
  .stub__note {
    color: var(--c-muted);
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
  }
</style>
