---
/**
 * Section « Qué obtienes » — grille bento façon spec technique : cartes à
 * bordure/ombre dures, numérotées, une en aplat sombre, une en aplat orange.
 * Bar-chart décoratif (pas de données réelles, pur motif visuel comme dans le
 * template source). Zéro photo — cohérent avec le système « sans image ».
 */
import { benefits } from '../data/benefits';

const [first, second, third] = benefits;
const bars = [45, 70, 55, 90, 65, 100, 80, 95];
---

<div class="bento">
  <article class="bento__card bento__card--wide reveal">
    <div class="bento__num">LBL—01</div>
    <div class="bento__body">
      <h3 class="bento__title">{first!.title}</h3>
      <p class="bento__text">{first!.text}</p>
    </div>
    <div class="bento__bars" aria-hidden="true">
      {bars.map((h) => <span style={`height:${h}%`} />)}
    </div>
  </article>

  <article class="bento__card bento__card--narrow bento__card--dark reveal">
    <div class="bento__num">LBL—02</div>
    <h3 class="bento__title">{second!.title}</h3>
    <div class="bento__stat">SEO</div>
  </article>

  <article class="bento__card bento__card--mid bento__card--safety reveal">
    <div class="bento__num">LBL—03</div>
    <h3 class="bento__title">{third!.title}</h3>
    <p class="bento__text">{third!.text}</p>
  </article>

  <article class="bento__card bento__card--mid reveal">
    <div class="bento__num">LBL—04</div>
    <h3 class="bento__title">100 % chileno</h3>
    <p class="bento__text">Trato local, sin intermediarios. Técnica francesa, presencia chilena.</p>
    <div class="bento__stat">100<span class="accent" style="font-size:0.4em">%</span></div>
  </article>
</div>

<style>
  .bento {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat(2, 1fr);
    gap: var(--space-md);
  }
  .bento__card {
    border: var(--border-hard);
    box-shadow: var(--shadow-hard);
    background: var(--c-paper);
    padding: clamp(1.25rem, 2vw, 2rem);
    display: grid;
    grid-template-rows: auto 1fr auto;
    gap: var(--space-sm);
    transition: var(--transition-snap);
  }
  .bento__card:hover {
    transform: translate(-4px, -4px);
    box-shadow: var(--shadow-hard-hover);
  }
  .bento__card--wide {
    grid-column: span 2;
    grid-row: span 2;
  }
  .bento__card--narrow {
    grid-column: span 1;
    grid-row: span 1;
  }
  .bento__card--mid {
    grid-column: span 2;
    grid-row: span 1;
  }
  .bento__card--dark {
    background: var(--c-dark);
    color: var(--c-paper);
    box-shadow: var(--shadow-hard-safety);
  }
  .bento__card--dark:hover {
    box-shadow: var(--shadow-hard-hover-safety);
  }
  .bento__card--safety {
    background: var(--c-line);
    color: var(--c-on-line);
  }

  .bento__num {
    font-family: var(--font-mono);
    font-size: var(--fs-label);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    opacity: 0.35;
  }
  .bento__title {
    font-size: var(--fs-lg);
    line-height: 0.95;
  }
  .bento__text {
    font-size: var(--fs-sm);
    line-height: 1.7;
    opacity: 0.65;
  }
  .bento__stat {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: var(--tracking-tight);
    align-self: end;
  }

  .bento__bars {
    display: flex;
    align-items: flex-end;
    gap: 4px;
    height: 3.5rem;
  }
  .bento__bars span {
    flex: 1;
    background: var(--c-line);
    border: 2px solid var(--c-ink);
    min-height: 4px;
  }

  @media (max-width: 60rem) {
    .bento {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: auto;
    }
    .bento__card--wide,
    .bento__card--mid {
      grid-column: span 2;
    }
    .bento__card--narrow {
      grid-column: span 1;
    }
  }
  @media (max-width: 34rem) {
    .bento {
      grid-template-columns: 1fr;
    }
    .bento__card--wide,
    .bento__card--mid,
    .bento__card--narrow {
      grid-column: span 1;
    }
  }
</style>
