---
/**
 * Section « Qué obtienes » — bento asymétrique. Grande tuile sombre avec photo
 * duotone (bénéfice phare), tuile orange pleine, tuile papier : les 3 surfaces
 * de marque en équilibre. Bénéfices PARALLÈLES → pas de numérotation.
 * Requiert le filtre `#duotone-orange` (inclure <Duotone /> dans la page).
 * À poser sur une section à fond clair (pas .section--alt).
 */
import { Image } from 'astro:assets';
import TrazoIcon from './TrazoIcon.astro';
import { benefits } from '../data/benefits';
import homeOffice from '../assets/home-office.jpg';

const [lead, second, third] = benefits;
---

<div class="bento">
  <article class="bento__tile bento__lead">
    <Image src={homeOffice} alt="" width={900} class="bento__img" />
    <div class="bento__body">
      <TrazoIcon name={lead!.icon} />
      <h3 class="bento__name">{lead!.title}</h3>
      <p class="bento__text">{lead!.text}</p>
    </div>
  </article>

  <article class="bento__tile bento__accent">
    <TrazoIcon name={second!.icon} />
    <h3 class="bento__name">{second!.title}</h3>
    <p class="bento__text">{second!.text}</p>
  </article>

  <article class="bento__tile bento__paper">
    <TrazoIcon name={third!.icon} />
    <h3 class="bento__name">{third!.title}</h3>
    <p class="bento__text">{third!.text}</p>
  </article>
</div>

<style>
  .bento {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: var(--space-md);
    min-height: 32rem;
  }
  .bento__tile {
    border-radius: var(--radius-lg);
    padding: clamp(1.5rem, 3vw, 2.25rem);
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }
  .bento__name {
    font-size: var(--fs-xl);
    margin-top: var(--space-2xs);
  }
  .bento__text {
    font-size: var(--fs-base);
    max-width: 34ch;
  }

  /* Tuile phare — sombre + photo duotone, texte en bas */
  .bento__lead {
    grid-row: 1 / 3;
    position: relative;
    overflow: hidden;
    background: var(--c-dark);
    justify-content: flex-end;
    color: var(--c-paper);
    min-height: 22rem;
  }
  .bento__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: url(#duotone-orange);
    opacity: 0.9;
  }
  .bento__lead .bento__body {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    padding: var(--space-lg);
    margin: calc(-1 * clamp(1.5rem, 3vw, 2.25rem));
    margin-top: 0;
    background: linear-gradient(to top, rgba(17, 17, 17, 0.92) 30%, rgba(17, 17, 17, 0) 100%);
  }
  .bento__lead .bento__text {
    color: rgba(255, 255, 255, 0.82);
  }
  .bento__lead :global(.trazo-icon) {
    color: var(--c-paper);
  }

  /* Tuile accent — aplat orange */
  .bento__accent {
    background: var(--c-accent);
    color: var(--c-on-line);
  }
  .bento__accent .bento__text {
    color: rgba(255, 255, 255, 0.9);
  }
  .bento__accent :global(.trazo-icon) {
    color: var(--c-on-line);
  }

  /* Tuile calme — papier + filet */
  .bento__paper {
    background: var(--c-paper);
    border: var(--border-thin);
    color: var(--c-ink);
  }
  .bento__paper .bento__text {
    color: var(--c-muted);
  }

  /* Tablette : la phare passe en haut pleine largeur, les 2 autres dessous */
  @media (max-width: 52rem) {
    .bento {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto;
    }
    .bento__lead {
      grid-row: auto;
      grid-column: 1 / 3;
    }
  }
  @media (max-width: 34rem) {
    .bento {
      grid-template-columns: 1fr;
    }
    .bento__lead {
      grid-column: auto;
    }
  }
</style>
