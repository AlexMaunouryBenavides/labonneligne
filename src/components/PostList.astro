---
/** Liste d'articles réutilisée par l'index blog et les pages de catégorie/tag. */
import type { Post } from '../lib/blog';
import PostMeta from './PostMeta.astro';

interface Props {
  posts: Post[];
}
const { posts } = Astro.props;
---

<ul role="list" class="posts">
  {
    posts.map((post) => (
      <li class="post">
        <PostMeta post={post} showReadingTime />
        <h2 class="post__title">
          <a href={`/blog/${post.id}`}>{post.data.title}</a>
        </h2>
        <p class="post__desc">{post.data.description}</p>
      </li>
    ))
  }
</ul>

<style>
  .posts {
    display: grid;
    gap: var(--space-lg);
    margin: 0;
    max-width: 52rem;
  }
  .post {
    padding-bottom: var(--space-lg);
    border-bottom: var(--border-thin);
  }
  .post:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }
  .post__title {
    font-size: var(--fs-xl);
    margin-top: var(--space-sm);
  }
  .post__title a {
    display: inline-block;
    text-decoration: none;
    transition: transform 0.15s var(--ease-out);
  }
  .post__title a:hover {
    color: var(--c-orange-ink);
    transform: translateX(0.4rem);
  }
  .post__desc {
    color: var(--c-muted);
    margin-top: var(--space-2xs);
    max-width: 60ch;
  }
</style>
