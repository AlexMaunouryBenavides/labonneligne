---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PlansGrid from '../components/PlansGrid.astro';
import ProjectList from '../components/ProjectList.astro';
import Proceso from '../components/Proceso.astro';
import Queo from '../components/Queo.astro';
import Cta from '../components/Cta.astro';
import LocalBusinessSchema from '../components/LocalBusinessSchema.astro';
import { projects } from '../data/projects';
import { whatsappUrl } from '../lib/contact';

const waHref = whatsappUrl();
const featuredProjects = projects.slice(0, 3);

const tickerA = [
  'Diseño Web',
  'SEO Local',
  'Hosting Incluido',
  'Mantención',
  'Planes en CLP',
  'Soporte en Español',
  'Sitios Rápidos',
];
const tickerB = ['La Bonne Ligne', 'Presencia 100% Chilena', 'Técnica Francesa', 'Precios Claros'];
---

<BaseLayout
  description="Diseño web para pymes en Chile: sitios rápidos, claros y con SEO local. Tecnología francesa, presencia 100 % chilena."
>
  <LocalBusinessSchema slot="head" />

  <!-- HERO — fond quadrillé, typo XXL, aucune photo. -->
  <section class="hero">
    <div class="grid-bg" aria-hidden="true"></div>
    <div class="container hero__inner">
      <p class="hero__label reveal">Diseño web · pymes · es-CL</p>
      <h1 class="hero__title">
        <span class="hero__line">Presencia web</span>
        <span class="hero__line hero__line--indent">que convierte<span class="accent">.</span></span
        >
      </h1>

      <div class="hero__bottom">
        <p class="hero__desc reveal">
          Sitios rápidos, claros y hechos para que tus clientes te encuentren. Tecnología francesa,
          presencia 100&nbsp;% chilena.
        </p>
        <ul role="list" class="hero__stats reveal">
          <li>
            <div class="hero__stat-num">100<span class="accent">%</span></div>
            <div class="hero__stat-label">Presencia chilena</div>
          </li>
          <li>
            <div class="hero__stat-num">3</div>
            <div class="hero__stat-label">Planes claros en CLP</div>
          </li>
          <li>
            <div class="hero__stat-num">FR<span class="accent">·</span>CL</div>
            <div class="hero__stat-label">Técnica francesa, trato local</div>
          </li>
        </ul>
      </div>

      <div class="hero__actions reveal">
        <Button href="/planes">Ver planes</Button>
        <Button href={waHref} variant="ghost">Hablar por WhatsApp</Button>
      </div>

      <span class="hero__scroll-cue" aria-hidden="true">Desplázate</span>
    </div>
  </section>

  <!-- TICKER — mots-clés de service, deux bandes contraires. -->
  <div class="ticker" aria-hidden="true">
    <div class="ticker__track">
      {[...tickerA, ...tickerA].map((item) => <span class="ticker__item">{item}</span>)}
    </div>
  </div>
  <div class="ticker ticker--safety ticker--reverse" aria-hidden="true">
    <div class="ticker__track">
      {[...tickerB, ...tickerB, ...tickerB].map((item) => <span class="ticker__item">{item}</span>)}
    </div>
  </div>

  <!-- QUÉ obtienes — bénéfices : bento (3 surfaces de marque) -->
  <section class="section section-divide">
    <div class="container">
      <SectionHeading eyebrow="Qué obtienes" title="Una presencia web que trabaja por ti" />
      <Queo />
    </div>
  </section>

  <!-- PLANES — aperçu -->
  <section class="section container section-divide">
    <SectionHeading
      eyebrow="Planes"
      title="Precios claros, en pesos chilenos"
      intro="Compra única o arriendo sin preocupaciones. Tú eliges."
    />
    <PlansGrid />
    <p class="more-link">
      <a href="/planes">Ver planes en detalle <span aria-hidden="true">→</span></a>
    </p>
  </section>

  <!-- CÓMO — processus -->
  <section class="section section-divide">
    <div class="container">
      <SectionHeading eyebrow="Cómo trabajamos" title="Simple, de principio a fin" />
      <Proceso />
    </div>
  </section>

  <!-- PROYECTOS — aperçu -->
  <section class="section container section-divide">
    <SectionHeading eyebrow="Proyectos" title="Sitios que dan resultados" />
    <ProjectList projects={featuredProjects} />
    <p class="more-link">
      <a href="/proyectos">Ver todos los proyectos <span aria-hidden="true">→</span></a>
    </p>
  </section>

  <!-- POR QUÉ — positionnement du duo -->
  <section class="section">
    <div class="container porque">
      <p class="eyebrow">Por qué La Bonne Ligne</p>
      <p class="porque__statement">
        Saber hacer técnico de <strong>Francia</strong>, acompañamiento cercano y
        <strong> 100 % chileno</strong>. Tú te dedicas a tu negocio; nosotros, a tu presencia en
        línea.
      </p>
      <Button href="/nosotros" variant="ghost">Conócenos</Button>
    </div>
  </section>

  <Cta />
</BaseLayout>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: clamp(3.5rem, 9vw, 7rem) clamp(2.5rem, 6vw, 4rem);
    border-bottom: var(--border-hard);
  }
  .hero__inner {
    position: relative;
    z-index: 1;
  }
  .hero__label {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-mono);
    font-size: var(--fs-label);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--c-orange-ink);
    margin-bottom: var(--space-md);
  }
  .hero__label::before {
    content: '';
    width: 2rem;
    height: 1px;
    background: var(--c-line);
  }

  .hero__title {
    font-size: var(--fs-hero);
    line-height: 0.86;
    margin-bottom: var(--space-xl);
  }
  .hero__line {
    display: block;
  }
  .hero__line--indent {
    padding-left: clamp(1rem, 6vw, 5rem);
  }
  .hero__title .accent {
    color: var(--c-orange-ink);
  }

  .hero__bottom {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-xl);
    flex-wrap: wrap;
    margin-bottom: var(--space-xl);
  }
  .hero__desc {
    max-width: 26rem;
    color: var(--c-muted);
    line-height: 1.8;
  }
  .hero__stats {
    display: flex;
    gap: clamp(1.5rem, 3vw, 3rem);
  }
  .hero__stat-num {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    font-size: var(--fs-stat);
    line-height: 1;
    letter-spacing: var(--tracking-tight);
  }
  .hero__stat-label {
    font-family: var(--font-mono);
    font-size: var(--fs-label);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--c-muted);
    margin-top: var(--space-2xs);
    max-width: 12ch;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .hero__scroll-cue {
    position: absolute;
    right: 0;
    bottom: -1rem;
    writing-mode: vertical-rl;
    font-family: var(--font-mono);
    font-size: var(--fs-label);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--c-muted);
    display: none;
  }

  .section-divide {
    border-bottom: var(--border-hard);
  }

  .more-link {
    margin-top: var(--space-lg);
    text-align: center;
  }
  .more-link a {
    font-family: var(--font-mono);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    font-size: var(--fs-sm);
    color: var(--c-orange-ink);
    text-decoration: none;
  }
  .more-link a:hover {
    text-decoration: underline;
  }

  .porque {
    max-width: 60rem;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    align-items: flex-start;
  }
  .porque__statement {
    font-family: var(--font-display);
    font-size: var(--fs-2xl);
    font-weight: var(--fw-semibold);
    line-height: var(--leading-snug);
    text-transform: none;
  }

  @media (min-width: 60rem) {
    .hero__scroll-cue {
      display: flex;
      align-items: center;
      gap: var(--space-sm);
    }
  }

  @media (max-width: 52rem) {
    .hero__bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-lg);
    }
    .hero__stats {
      flex-wrap: wrap;
    }
  }
</style>
