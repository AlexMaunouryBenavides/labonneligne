---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Nosotros" description="La Bonne Ligne: tecnología francesa, presencia 100 % chilena.">
  <section class="section container stub">
    <p class="eyebrow">Nosotros</p>
    <h1>Quiénes somos</h1>
    <hr class="rule-line" />
    <p class="stub__note">Próximamente — nuestra historia llega en la siguiente etapa.</p>
  </section>
</BaseLayout>

<style>
  .stub { min-height: 50svh; }
  .stub h1 { margin-top: var(--space-sm); }
  .rule-line { margin-block: var(--space-md); }
  .stub__note { color: var(--c-muted); font-family: var(--font-mono); font-size: var(--fs-sm); }
</style>
