---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Proceso from '../components/Proceso.astro';
import Duotone from '../components/Duotone.astro';
import Cta from '../components/Cta.astro';

const guarantees = [
  { title: 'Plazos claros', text: 'Acordamos el plazo antes de empezar y lo cumplimos.' },
  { title: 'Revisiones incluidas', text: 'Ajustamos tu sitio hasta que quede bien.' },
  {
    title: 'Sin preocupaciones',
    text: 'En arriendo, hospedaje y mantención van por nuestra cuenta.',
  },
  { title: 'Trato humano', text: 'Hablas siempre con una persona, en tu idioma.' },
];
---

<BaseLayout
  title="Nosotros"
  description="La Bonne Ligne: saber hacer técnico de Francia y una presencia cercana, 100 % chilena."
>
  <section class="section container">
    <SectionHeading
      as="h1"
      eyebrow="Nosotros"
      title="Tecnología francesa, presencia 100 % chilena"
    />
    <div class="duo">
      <p class="duo__lead">
        La Bonne Ligne nace de una idea simple: unir el saber hacer técnico de Francia con un
        acompañamiento cercano, en Chile y en tu idioma.
      </p>
      <p class="duo__text">
        Alexandre, desarrollador en Francia, diseña y construye cada sitio con estándares exigentes.
        En Chile te acompañamos de cerca: respondemos rápido, entendemos tu mercado y estamos cuando
        nos necesitas. Tú te dedicas a tu negocio; nosotros, a tu presencia en línea.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeading eyebrow="Cómo trabajamos" title="Simple, de principio a fin" />
      <Duotone />
      <Proceso />
    </div>
  </section>

  <section class="section container">
    <SectionHeading eyebrow="Garantías" title="Lo que puedes esperar de nosotros" />
    <ul role="list" class="guarantees">
      {
        guarantees.map((item) => (
          <li class="guarantee">
            <h3 class="guarantee__title">{item.title}</h3>
            <p class="guarantee__text">{item.text}</p>
          </li>
        ))
      }
    </ul>
  </section>

  <Cta />
</BaseLayout>

<style>
  .duo {
    display: grid;
    gap: var(--space-md);
    max-width: 60rem;
  }
  .duo__lead {
    font-family: var(--font-display);
    font-size: var(--fs-xl);
    font-weight: var(--fw-semibold);
    line-height: var(--leading-snug);
  }
  .duo__text {
    color: var(--c-muted);
    font-size: var(--fs-lg);
    max-width: 62ch;
  }

  .guarantees {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
    margin: 0;
    max-width: 60rem;
  }
  .guarantee {
    padding-left: var(--space-sm);
    border-left: 2px solid var(--c-line);
  }
  .guarantee__title {
    font-size: var(--fs-lg);
  }
  .guarantee__text {
    color: var(--c-muted);
    font-size: var(--fs-sm);
    margin-top: var(--space-3xs);
  }
  @media (max-width: 40rem) {
    .guarantees {
      grid-template-columns: 1fr;
    }
  }
</style>
