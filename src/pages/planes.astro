---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Planes" description="Planes de diseño web para pymes: vitrina, estándar y a medida. En compra única o arriendo.">
  <section class="section container stub">
    <p class="eyebrow">Planes</p>
    <h1>Planes y precios</h1>
    <hr class="rule-line" />
    <p class="stub__note">Próximamente — la grilla de planes llega en la siguiente etapa.</p>
  </section>
</BaseLayout>

<style>
  .stub { min-height: 50svh; }
  .stub h1 { margin-top: var(--space-sm); }
  .rule-line { margin-block: var(--space-md); }
  .stub__note { color: var(--c-muted); font-family: var(--font-mono); font-size: var(--fs-sm); }
</style>
