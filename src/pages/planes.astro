---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PlansGrid from '../components/PlansGrid.astro';
import Cta from '../components/Cta.astro';
import { includedEverywhere } from '../data/plans';

const faqs = [
  {
    q: '¿Cuál es la diferencia entre compra y arriendo?',
    a: 'En compra única, el sitio es tuyo. En arriendo, nosotros lo alojamos y mantenemos por una mensualidad, con un compromiso de 12 a 24 meses.',
  },
  {
    q: '¿Qué pasa al final del arriendo?',
    a: 'Lo conversamos contigo antes del vencimiento: puedes renovar o detener el servicio.',
  },
  {
    q: '¿El hospedaje y la mantención están incluidos?',
    a: 'Sí, en el arriendo. En compra única el sitio queda alojado y puedes contratar la mantención aparte.',
  },
  {
    q: '¿Hacen tiendas online o back-end?',
    a: 'Sí, como proyecto a medida, cotizado por separado.',
  },
];
---

<BaseLayout
  title="Planes"
  description="Planes de diseño web para pymes en Chile: vitrina, estándar y a medida. En compra única o arriendo, precios en CLP."
>
  <section class="section container">
    <SectionHeading
      as="h1"
      eyebrow="Planes y precios"
      title="Un plan para cada etapa de tu empresa"
      intro="Precios claros en pesos chilenos. Elige comprarlo una vez o arrendarlo sin preocuparte de nada."
    />
    <PlansGrid />

    <div class="included">
      <p class="eyebrow">Incluido en todos los planes</p>
      <ul role="list" class="included__list">
        {includedEverywhere.map((item) => <li>{item}</li>)}
      </ul>
      <p class="included__sea">
        ¿Publicidad en Google? Gestionamos tu campaña (SEA) <strong>sobre cotización</strong>, según
        tu presupuesto.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container faq">
      <SectionHeading eyebrow="Preguntas frecuentes" title="Lo que suelen preguntarnos" />
      <div class="faq__list">
        {
          faqs.map((item, i) => (
            <div class="faq__item">
              <button
                type="button"
                class="faq__q"
                aria-expanded="false"
                aria-controls={`faq-panel-${i}`}
                id={`faq-q-${i}`}
              >
                {item.q}
                <span class="faq__icon" aria-hidden="true">
                  <span />
                  <span />
                </span>
              </button>
              <div
                class="faq__panel"
                id={`faq-panel-${i}`}
                role="region"
                aria-labelledby={`faq-q-${i}`}
              >
                <p class="faq__a">{item.a}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <Cta />
</BaseLayout>

<script>
  import { gsap } from 'gsap';

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // astro:page-load : le contenu de <main> est remplacé à chaque navigation
  // (transitions client-side) — ce script doit se ré-exécuter sur le DOM frais,
  // pas seulement au premier chargement.
  function initFaq() {
    document.querySelectorAll<HTMLElement>('.faq__item').forEach((item) => {
      const button = item.querySelector<HTMLButtonElement>('.faq__q');
      const panel = item.querySelector<HTMLElement>('.faq__panel');
      const answer = item.querySelector<HTMLElement>('.faq__a');
      if (!button || !panel || !answer) return;

      gsap.set(panel, { height: 0 });
      gsap.set(answer, { opacity: 0, y: -6 });

      let animating = false;

      button.addEventListener('click', () => {
        if (animating) return;
        const opening = button.getAttribute('aria-expanded') !== 'true';
        button.setAttribute('aria-expanded', String(opening));
        item.classList.toggle('is-open', opening);
        animating = true;

        if (opening) {
          const targetHeight = answer.offsetHeight;
          if (prefersReduced) {
            gsap.set(panel, { height: 'auto' });
            gsap.set(answer, { opacity: 1, y: 0 });
            animating = false;
            return;
          }
          gsap
            .timeline({
              onComplete: () => {
                gsap.set(panel, { height: 'auto' });
                animating = false;
              },
            })
            .to(panel, { height: targetHeight, duration: 0.4, ease: 'power2.out' })
            .to(answer, { opacity: 1, y: 0, duration: 0.3, ease: 'power2.out' }, 0.08);
        } else {
          const startHeight = panel.offsetHeight;
          gsap.set(panel, { height: startHeight });
          if (prefersReduced) {
            gsap.set(panel, { height: 0 });
            gsap.set(answer, { opacity: 0, y: -6 });
            animating = false;
            return;
          }
          gsap
            .timeline({ onComplete: () => (animating = false) })
            .to(answer, { opacity: 0, y: -6, duration: 0.18, ease: 'power2.in' })
            .to(panel, { height: 0, duration: 0.32, ease: 'power2.inOut' }, 0.02);
        }
      });
    });
  }

  document.addEventListener('astro:page-load', initFaq);
</script>

<style>
  .included {
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: var(--border-thin);
  }
  .included__list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xs) var(--space-md);
    margin: var(--space-sm) 0;
  }
  .included__list li {
    position: relative;
    padding-left: 1.4rem;
    font-weight: var(--fw-medium);
  }
  .included__list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 0.8rem;
    height: 2px;
    background: var(--c-line);
    border-radius: var(--radius-pill);
  }
  .included__sea {
    color: var(--c-muted);
    max-width: 52ch;
  }

  .faq__list {
    display: flex;
    flex-direction: column;
    max-width: 48rem;
    border-top: var(--border-thin);
  }
  .faq__item {
    border-bottom: var(--border-thin);
  }
  .faq__q {
    width: 100%;
    cursor: pointer;
    background: none;
    border: 0;
    padding: var(--space-sm) 0;
    font-family: var(--font-display);
    font-weight: var(--fw-semibold);
    font-size: var(--fs-lg);
    text-transform: none;
    letter-spacing: normal;
    color: var(--c-ink);
    text-align: left;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
  }
  .faq__q:hover {
    color: var(--c-orange-ink);
  }

  /* Icône « + » qui pivote en « × » à l'ouverture */
  .faq__icon {
    position: relative;
    flex: none;
    width: 1rem;
    height: 1rem;
  }
  .faq__icon span {
    position: absolute;
    inset: 0;
    margin: auto;
    background: var(--c-orange-ink);
    transition: transform 0.3s var(--ease-out);
  }
  .faq__icon span:first-child {
    width: 100%;
    height: 2px;
  }
  .faq__icon span:last-child {
    width: 2px;
    height: 100%;
  }
  .faq__item.is-open .faq__icon span:last-child {
    transform: rotate(90deg) scaleY(0);
  }

  .faq__panel {
    overflow: hidden;
    height: 0;
  }
  .faq__a {
    padding-bottom: var(--space-sm);
    color: var(--c-muted);
    max-width: 60ch;
  }
</style>
