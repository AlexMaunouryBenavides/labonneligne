---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ProjectList from '../components/ProjectList.astro';
import Cta from '../components/Cta.astro';
import { projects } from '../data/projects';
---

<BaseLayout
  title="Proyectos"
  description="Sitios web realizados por La Bonne Ligne y ejemplos por sector para pymes chilenas."
>
  <section class="section container">
    <SectionHeading
      as="h1"
      eyebrow="Proyectos"
      title="Sitios que trabajan por tu negocio"
      intro="Algunas realizaciones y ejemplos por sector. Así puede verse el tuyo."
    />
    <ProjectList projects={projects} />
  </section>

  <Cta title="¿Te imaginas el tuyo?" text="Cuéntanos tu rubro y te mostramos cómo se vería." />
</BaseLayout>
