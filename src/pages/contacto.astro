---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contacto" description="Conversemos sobre tu sitio web. Escríbenos por WhatsApp o por el formulario.">
  <section class="section container stub">
    <p class="eyebrow">Contacto</p>
    <h1>Conversemos</h1>
    <hr class="rule-line" />
    <p class="stub__note">Próximamente — el formulario llega en la siguiente etapa.</p>
  </section>
</BaseLayout>

<style>
  .stub { min-height: 50svh; }
  .stub h1 { margin-top: var(--space-sm); }
  .rule-line { margin-block: var(--space-md); }
  .stub__note { color: var(--c-muted); font-family: var(--font-mono); font-size: var(--fs-sm); }
</style>
